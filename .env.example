# AI provider — set ONE of these. KIMI_API_KEY takes priority over OPENAI_API_KEY.
KIMI_API_KEY=sk-...          # Kimi (Moonshot AI) — https://platform.moonshot.cn
OPENAI_API_KEY=sk-...        # OpenAI fallback (optional)

# Override the model name (optional — defaults shown below)
# Kimi default:   moonshot-v1-32k   (also available: moonshot-v1-8k, moonshot-v1-128k)
# OpenAI default: gpt-4.1-mini
AI_MODEL=

# VALIDATION_MODEL=gpt-4.1-mini  # optional override for the validator AI model
