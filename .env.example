# AI provider — set ONE of these. KIMI_API_KEY takes priority over OPENAI_API_KEY.
KIMI_API_KEY=sk-...          # Kimi (Moonshot AI) — https://platform.moonshot.cn
OPENAI_API_KEY=sk-...        # OpenAI fallback (optional)

# Kimi / Moonshot API settings
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=moonshot-v1-32k

# Override the model name (optional — defaults shown below)
# Kimi default:   moonshot-v1-32k   (also available: moonshot-v1-8k, moonshot-v1-128k)
# OpenAI default: gpt-4.1-mini
AI_MODEL=

# VALIDATION_MODEL=gpt-4.1-mini  # optional override for the validator AI model

# Optional local Slicer service
# For local dev only: http://127.0.0.1:8787
# For Vercel production, use a tunnel or VPS URL
SLICER_SERVICE_URL=http://127.0.0.1:8787
SLICER_EXE=C:\ProgramData\slicer.org\3D Slicer 5.10.0\Slicer.exe
SLICER_SCRIPT=scripts\analyze_slicer.py
OUTPUT_ROOT=outputs\slicer

# Safety
APP_MODE=clinical_decision_support_only
